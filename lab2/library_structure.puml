@startuml
skinparam componentStyle uml2
title Структура ИС "Библиотека"
 
package "Клиентская часть" {
  [Веб-интерфейс читателя]
  [Панель библиотекаря]
}
 
package "Серверная часть" {
  [API-сервер (Flask)]
  [Модуль авторизации]
  [Бизнес-логика]
}
 
database "База данных" {
  [PostgreSQL]
}
 
[Веб-интерфейс читателя] --> [API-сервер (Flask)] : HTTP
[Панель библиотекаря] --> [API-сервер (Flask)] : HTTP
[API-сервер (Flask)] --> [Модуль авторизации]
[API-сервер (Flask)] --> [Бизнес-логика]
[Бизнес-логика] --> [PostgreSQL] : SQL
@enduml
