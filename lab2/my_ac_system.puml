@startuml
skinparam componentStyle uml2
title Структура ИС "Танцевальная студия"

package "Клиентская часть" {
  [Веб-интерфейс пользователя]
  [Панель администратора]
}

package "Серверная часть" {
  [API-сервер (Flask)]
  [Модуль авторизации]
  [Бизнес-логика]
}

database "База данных" {
  [PostgreSQL]
}

[Веб-интерфейс пользователя] --> [API-сервер (Flask)] : HTTP
[Панель администратора] --> [API-сервер (Flask)] : HTTP
[API-сервер (Flask)] --> [Модуль авторизации]
[API-сервер (Flask)] --> [Бизнес-логика]
[Бизнес-логика] --> [PostgreSQL] : SQL

@enduml